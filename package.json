{
  "name": "bookmark-navigator",
  "version": "0.1.0",
  "description": "Chrome Extension - Vim-style bookmark navigator like Telescope/Raycast",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && vite build --mode keyblock && vite build --mode background && node copy-assets.mjs",
    "build:content": "vite build",
    "build:background": "vite build --mode background",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fuse.js": "^7.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}